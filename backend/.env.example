APP_ENV=dev

# Shared configuration for backend services (loaded via Viper + YAML).

# Finance API configuration (prefix: FINANCE_API_)
FINANCE_API_APPNAME=moon-eye-finance-api
# Address the finance-api listens on (host:port).
FINANCE_API_SERVER_ADDR=:8080

# PostgreSQL connection string for finance-api.
# Example: postgres://user:password@localhost:5432/moon_eye_finance?sslmode=disable
FINANCE_API_DATABASE_URL=postgres://user:password@localhost:5432/moon_eye_finance?sslmode=disable

# Redis connection string for queues / caching.
# Example: redis://localhost:6379/0
FINANCE_API_REDIS_URL=redis://localhost:6379/0

# Logging level for finance-api (e.g. debug, info, warn, error).
FINANCE_API_LOGGING_LEVEL=info


# Auth service configuration (prefix: AUTH_SERVICE_)
AUTH_SERVICE_APPNAME=moon-eye-auth-service

# JWT secret used to sign auth tokens (change in production).
AUTH_SERVICE_AUTH_JWTSECRET=changeme-in-prod

# Optional: auth-service server address (if/when wired into shared config).
# AUTH_SERVICE_SERVER_ADDR=:8081

